{
  "name": "worlds",
  "private": true,
  "workspaces": [
    "backend",
    "server",
    "demo"
  ],
  "scripts": {
    "backend": "npm run dev --workspace=backend",
    "build:backend": "npm run build --workspace=backend",
    "test:backend": "npm run test --workspace=backend",
    "mobile": "npm --prefix mobile start",
    "check:mobile": "npm --prefix mobile run check",
    "server": "npm run dev --workspace=server",
    "demo": "npm run dev --workspace=demo",
    "test": "npm run test --workspace=server",
    "build:server": "npm run build --workspace=server"
  }
}
